<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D0D"
    tools:context=".ui.MainActivity">

    <!-- Top status bar -->
    <LinearLayout
        android:id="@+id/statusBar"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="#111122"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:id="@+id/statusIndicator"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="@drawable/circle_red"/>

        <TextView
            android:id="@+id/statusText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="@string/status_disconnected"
            android:textColor="#888888"
            android:textSize="14sp"/>

        <TextView
            android:id="@+id/deviceNameText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MYSTRIX"
            android:textColor="#6C63FF"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:visibility="gone"/>

        <ImageButton
            android:id="@+id/settingsButton"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="12dp"
            android:src="@drawable/cog"
            android:scaleType="centerInside"
            android:background="@drawable/circle_red"
            android:contentDescription="@string/settings"
            android:padding="4dp"/>
    </LinearLayout>

    <!-- 8x8 Pad Grid -->
    <com.matrix.midiemulator.ui.PadGridView
        android:id="@+id/padGrid"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/statusBar"
        app:layout_constraintBottom_toTopOf="@id/touchbarContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintWidth_percent="0.92"
        android:layout_marginTop="12dp"/>

    <!-- Touchbar strip -->
    <LinearLayout
        android:id="@+id/touchbarContainer"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        app:layout_constraintBottom_toTopOf="@id/fnButtonContainer"
        app:layout_constraintStart_toStartOf="@id/padGrid"
        app:layout_constraintEnd_toEndOf="@id/padGrid"/>

    <!-- FN Button -->
    <FrameLayout
        android:id="@+id/fnButtonContainer"
        android:layout_width="0dp"
        android:layout_height="44dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="@id/padGrid"
        app:layout_constraintEnd_toEndOf="@id/padGrid">

        <TextView
            android:id="@+id/fnButton"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="FN"
            android:textColor="#AAAAAA"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:background="@drawable/pad_default"/>
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
