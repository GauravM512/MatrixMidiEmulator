<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#090A0C"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="18dp"
        android:paddingEnd="18dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_title"
                    android:textColor="#F6F7FB"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:text="@string/settings_subtitle"
                    android:textColor="#9AA1AD"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/appVersionText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="#6F7784"
                    android:textSize="12sp" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/githubButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/settings_icon_button_background"
                android:contentDescription="@string/github_link"
                android:padding="12dp"
                android:src="@drawable/ic_github"
                app:tint="#F6F7FB" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            app:cardBackgroundColor="#15171C"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:strokeColor="#292D36"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/setting_appearance"
                    android:textColor="#B9C0CA"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/landscapePadsSwitch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/setting_landscape_pads"
                    android:textColor="#F6F7FB"
                    android:textSize="15sp"
                    app:useMaterialThemeColors="true" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/immersiveModeSwitch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/setting_immersive_mode"
                    android:textColor="#F6F7FB"
                    android:textSize="15sp"
                    app:useMaterialThemeColors="true" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/showConnectionStatusSwitch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/setting_show_connection_status"
                    android:textColor="#F6F7FB"
                    android:textSize="15sp"
                    app:useMaterialThemeColors="true" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/flickerReductionSwitch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/setting_flicker_reduction"
                    android:textColor="#F6F7FB"
                    android:textSize="15sp"
                    app:useMaterialThemeColors="true" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/launchpadIdentitySwitch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/setting_launchpad_identity"
                    android:textColor="#F6F7FB"
                    android:textSize="15sp"
                    app:useMaterialThemeColors="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/setting_layout_mode"
                    android:textColor="#F6F7FB"
                    android:textSize="14sp" />

                <Spinner
                    android:id="@+id/layoutModeSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/settings_field_background"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardBackgroundColor="#15171C"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:strokeColor="#292D36"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/setting_effect_brightness"
                    android:textColor="#B9C0CA"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/brightnessValueText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/setting_brightness_value"
                    android:textColor="#F6F7FB"
                    android:textSize="15sp" />

                <SeekBar
                    android:id="@+id/brightnessSeekBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:max="200"
                    android:progress="100" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/resetBrightnessButton"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="10dp"
                    android:text="@string/setting_brightness_reset"
                    android:textColor="#F6F7FB"
                    app:cornerRadius="8dp"
                    app:strokeColor="#3A404D" />

                <com.matrix.midiemulator.ui.PadGridView
                    android:id="@+id/brightnessPreviewGrid"
                    android:layout_width="220dp"
                    android:layout_height="220dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/settings_preview_background"
                    android:clickable="false"
                    android:focusable="false" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardBackgroundColor="#15171C"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:strokeColor="#292D36"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/setting_pages"
                    android:textColor="#B9C0CA"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/setting_pages_hint"
                    android:textColor="#9AA1AD"
                    android:textSize="14sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardBackgroundColor="#15171C"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:strokeColor="#292D36"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/setting_palette"
                    android:textColor="#B9C0CA"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/setting_palette_source"
                    android:textColor="#F6F7FB"
                    android:textSize="14sp" />

                <Spinner
                    android:id="@+id/paletteSourceSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/settings_field_background"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/setting_palette_import_slot"
                    android:textColor="#F6F7FB"
                    android:textSize="14sp" />

                <Spinner
                    android:id="@+id/paletteImportSlotSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/settings_field_background"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/setting_palette_import_hint"
                    android:textColor="#9AA1AD"
                    android:textSize="13sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/importPaletteButton"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="12dp"
                    android:text="@string/setting_palette_import_file"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="#E43F5A"
                    app:cornerRadius="8dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</ScrollView>
